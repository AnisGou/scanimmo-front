# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Mapbox
NEXT_PUBLIC_MAPBOX_TOKEN=pk.eyJ...

# Public app URL
NEXT_PUBLIC_BASE_URL=https://scanimmo.ca
NEXT_PUBLIC_APP_URL=https://scanimmo.ca

# Contact form
CONTACT_EMAIL_TO=your-contact-destination@example.com
# Optional. If omitted, the form still stores messages in Supabase.
CONTACT_EMAIL_FROM=no-reply@scanimmo.ca
# Optional. If set, the server also attempts email delivery in addition to Supabase storage.
SMTP_URL=smtps://username:password@smtp.example.com:465
# Or use the discrete SMTP vars below instead of SMTP_URL
# SMTP_HOST=smtp.example.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=username
# SMTP_PASS=password
